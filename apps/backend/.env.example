# Marketing Engine Environment Configuration

# Copy this file to `.env` and fill in your values

# ===========================================
# PROVIDER CONFIGURATION
# ===========================================

# ----- Mailchimp (Email) -----
# Sign up at https://mailchimp.com
# Get your API key from: Account > Extras > API keys
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_SERVER=us1  # e.g., us1, us2, us3 (check your Mailchimp URL)
MAILCHIMP_DOMAIN=yourdomain.com  # Verified sending domain

# ----- Plivo (SMS) -----
# Sign up at https://plivo.com
# Get from Dashboard: Auth ID and Auth Token
PLIVO_AUTH_ID=your_plivo_auth_id_here
PLIVO_AUTH_TOKEN=your_plivo_auth_token_here
PLIVO_PHONE_NUMBER=+15551234567  # Your purchased phone number

# ===========================================
# EMAIL DEFAULTS
# ===========================================
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
DEFAULT_FROM_NAME=Marketing Engine

# ===========================================
# DATABASE (if using)
# ===========================================
DATABASE_URL=sqlite:///./marketing_engine.db

# ===========================================
# API KEYS
# ===========================================
# Add any other API keys here

# ===========================================
# SETUP INSTRUCTIONS
# ===========================================
#
# 1. Mailchimp:
#    - Sign up at mailchimp.com
#    - Go to Account > Extras > API keys
#    - Create new API key
#    - Check your URL for server (us1, us2, etc.)
#
# 2. Plivo:
#    - Sign up at plivo.com
#    - Go to Dashboard > Account > Credentials
#    - Buy a phone number from Phone Numbers
#    - Add Auth ID and Auth Token to this file
#
# 3. Copy to .env:
#    cp .env.example .env
#    # Then edit .env with your actual values
#