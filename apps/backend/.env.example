# Marketing Engine Environment Configuration

# Copy this file to `.env` and fill in your values

# ===========================================
# PROVIDER CONFIGURATION
# ===========================================

# ----- Brevo (Email) -----
# Sign up at https://www.brevo.com (formerly Sendinblue)
# Free tier: 300 emails/day
# Get your API key from: SMTP > API Key
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Marketing Engine

# ----- Twilio (SMS) -----
# Sign up at https://twilio.com
# Get from Console: Account SID and Auth Token
# Buy a phone number from Phone Numbers
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+18761234567  # Your purchased Jamaican phone number

# ===========================================
# DATABASE (if using)
# ===========================================
DATABASE_URL=sqlite:///./marketing_engine.db

# ===========================================
# SETUP INSTRUCTIONS
# ===========================================
#
# 1. Brevo (Email):
#    - Sign up at brevo.com
#    - Go to SMTP > API Key
#    - Create new API key
#    - Verify your sender email
#    - Free: 300 emails/day
#
# 2. Twilio (SMS):
#    - Sign up at twilio.com
#    - Go to Console > Dashboard
#    - Copy Account SID and Auth Token
#    - Buy a Jamaican phone number (+1 876)
#
# 3. Copy to .env:
#    cp .env.example .env
#    # Then edit .env with your actual values
#
# ===========================================
# EMAIL PROVIDER COMPARISON
# ===========================================
#
# Provider    | Free Tier        | Cost After   | Best For
# ------------|------------------|--------------|------------------
# Brevo       | 300/day          | $25/mo       | Low volume (you)
# Mailchimp   | 10k/mo, 500 cont | $10/mo       | Growing lists
# Amazon SES  | 62k/mo (AWS)     | $0.10/1k     | High volume
# Resend      | 3k/mo            | $5/10k       | Developers
#