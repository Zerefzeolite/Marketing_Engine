# Marketing Engine - Environment Variables Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env with real secrets to git

# Brevo (formerly Sendinblue) - Email Service
BREVO_API_KEY=your_brevo_api_key_here

# Twilio - SMS Service  
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Database (if using PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/marketing_engine

# Optional: Set to "true" for development mode features
# NEXT_PUBLIC_DEBUG=true